# ============================================================
# SummitOS / COS Tesla — Hardened .gitignore
# DO NOT commit secrets, build artifacts, or local state
# ============================================================

# ========================
# SECRETS — NEVER COMMIT
# ========================
.env
.env.*
!.env.example
!.env.template
**/.env
**/.env.*
!**/.env.example
!**/.env.template
*.env.local
*.env.production
*.env.development
local.settings.json
.env.sharepoint
.env.test
.env.receipt-engine.template
*-settings.json
*_settings.json
device_code_secret.txt
auth_code*.txt
ropc_*.txt
token.pickle

# Android / Play signing — IRREPLACEABLE, NEVER COMMIT (repo is PUBLIC)
*.keystore
*.jks
signing-key-info.txt
*.aab
*.apk

# ========================
# BUILD ARTIFACTS
# ========================
/.next/
frontend/.next/
frontend/.next_old/
frontend/out/
/build
frontend/build
.vercel/

# ========================
# DEPENDENCIES
# ========================
/node_modules
frontend/node_modules/
backend/.python_packages/
backend/venv32/
backend/.venv/
.venv/
/.pnp
.pnp.js

# ========================
# PYTHON
# ========================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.pyd
*.egg-info/

# ========================
# DEPLOYMENT ZIPS (large binary artifacts)
# ========================
*.zip
backend/deploy.zip
backend_deploy.zip

# ========================
# LOGS & DEBUG OUTPUT
# ========================
*.log
*.ndjson
Audit_Log.ndjson
run_log*.txt
debug_*.txt
process_trips*.log
swa_*.txt
push_output.txt
diag_output.json
forms_output.txt
graph_output.json
schema_output.txt
debug_output.txt
test_write.txt

# ========================
# OS / EDITOR
# ========================
.DS_Store
*.pem
desktop.ini
.vscode/settings.json
*.tsbuildinfo
tsconfig.tsbuildinfo

# ========================
# SCRATCH & TEMP
# ========================
scratch/
temp.json
to_cloud_search.txt
0
=

# ========================
# MISC / SENSITIVE
# ========================
graph_roles.json
app_perms.json
func-summit-sync-prod-settings.json
summitos-api-settings.json
summitsyncfunc-settings.json
Sales_Report_*.csv
