# .funcignore - Files excluded from Azure Function deployment zip
# SECURITY: Ensures secrets and dev-only files never ship to Azure

# === SECRETS (NEVER DEPLOY) ===
local.settings.json
.env
.env.*
*.env.local
*.env.production
*.env.development
.env.sharepoint
.env.test
.env.receipt-engine.template
config/.env
finance_mcp/.env
*-settings.json
*_settings.json
credentials/
*.pem
*.key
*.p12

# === SOURCE CONTROL ===
.git*
.github/

# === DEVELOPMENT TOOLS ===
.vscode/
.venv/
venv32/
.python_packages/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# === TEST & DIAGNOSTIC FILES ===
test_*.py
*_test.py
tests/
diagnostic_*.py
verify_*.py
check_*.py
scratch/

# === DEPLOYMENT ARTIFACTS (already deployed) ===
*.zip
*.bak
deploy*.ps1
deploy*.zip
backend_deploy*.zip
*_deploy.zip
backend_fix.zip

# === LOGS & TEMP ===
*.log
*.ndjson
Audit_Log.ndjson
run_log*.txt
debug_*.txt
process_trips*.log

# === DOCS (not needed at runtime) ===
*.md
README*

# === SCRIPTS (run locally only) ===
scripts/