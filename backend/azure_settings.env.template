# ==========================================
# SummitOS Backend — Azure App Settings
# ==========================================
# This file is a TEMPLATE only.
# NEVER put real values here.
# Copy to Azure Portal → Function App → Configuration → Application Settings
# (or push via: az functionapp config appsettings set --settings @azure_settings.env)
# ==========================================

# --- Runtime ---
FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsFeatureFlags=EnableWorkerIndexing

# --- Azure Storage (use Managed Identity where possible) ---
# AzureWebJobsStorage=<connection_string_or_managed_identity>

# --- Key Vault (PRIMARY secret source in production) ---
KEYVAULT_URL=https://summitos-kv.vault.azure.net/

# --- OAuth / Graph API ---
OAUTH_TENANT_ID=<from-key-vault-or-app-setting>
OAUTH_CLIENT_ID=<from-key-vault-or-app-setting>
OAUTH_CLIENT_SECRET=<use-key-vault>

# --- OpenAI ---
OPENAI_API_KEY=<use-key-vault>

# --- SQL ---
SQL_CONNECTION_STRING=<use-key-vault>

# --- Azure Vision ---
AZURE_VISION_KEY=<use-key-vault>
AZURE_VISION_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# --- Microsoft Bookings ---
MS_BOOKINGS_BUSINESS_ID=SummitOS@costesla.com
MS_BOOKINGS_SERVICE_ID=dc16877c-160d-436e-b53b-52ae6f419604

# --- Stripe ---
STRIPE_SECRET_KEY=<use-key-vault>

# --- Tessie (Tesla) ---
TESSIE_API_KEY=<use-key-vault>
TESSIE_VIN=7SAYGDEEXRF075302

# --- Google APIs ---
GOOGLE_PLACES_API_KEY=<use-key-vault>
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<use-key-vault>

# --- Aviation (flight status: hybrid FlightAware + Flightradar24) ---
FLIGHTAWARE_API_KEY=<use-key-vault>
FLIGHTRADAR24_API_TOKEN=<use-key-vault>

# --- Email ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=PrivateTrips@costesla.com
SMTP_PASS=<use-key-vault>

# --- Internal Auth ---
# Set this to a strong random value and use it in x-functions-key header
AZURE_FUNCTION_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(40))">
INTERNAL_API_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(40))">

# --- CORS ---
# Comma-separated list of allowed origins. NO wildcards.
ALLOWED_ORIGINS=https://www.costesla.com,https://costesla.com,https://www.dashboardcostesla.com,https://dashboardcostesla.com

# --- Site ---
SITE_URL=https://www.costesla.com

# --- OneDrive / File Counting ---
# Set ONEDRIVE_USER_EMAIL to query the user's personal work OneDrive (recommended).
# Files must exist at: <root>/Uber Driver/YYYY/Month/Week X/M.DD.YY/
# Requires Files.Read.All or Sites.Read.All Graph API permission.
ONEDRIVE_USER_EMAIL=peter.teehan@costesla.com
# Alternatively, set an explicit Drive ID to skip dynamic resolution entirely:
# ONEDRIVE_DRIVE_ID=<drive-id-from-graph-explorer>
