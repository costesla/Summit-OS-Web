# SummitOS Dashboard — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# DO NOT commit .env.local or .env — they are in .gitignore.
#
# In production (Azure Static Web Apps), set these in the portal under
# Settings → Configuration → Application settings.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=https://summitos-api.azurewebsites.net/api

# App version — injected automatically by CI from package.json
VITE_APP_VERSION=1.4.5

# Telemetry — set to "false" to suppress console telemetry in local dev
VITE_TELEMETRY_ENABLED=true

# Optional: URL of a telemetry sink (e.g. Azure Monitor ingestion endpoint)
# Leave blank to log to console only. No API keys here — use Azure Managed Identity.
VITE_TELEMETRY_SINK_URL=

# Optional: override the deployment base path (e.g. /dashboard/)
VITE_BASE_PATH=/

# Sourcemaps in production — default false. Set true in staging only.
VITE_SOURCEMAP=false
