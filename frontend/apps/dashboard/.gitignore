# ─── Build Output — NEVER COMMIT ──────────────────────────────────────────────
# dist/ is generated by `npm run build`. Do not commit it.
# Azure Static Web Apps picks up dist/ from the CI pipeline, not source control.
dist/
dist-ssr/

# TypeScript incremental build cache
*.tsbuildinfo

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Environment / Secrets — NEVER COMMIT ─────────────────────────────────────
# Use Azure Static Web App environment variables for runtime config.
# Local overrides go here but must never be checked in.
.env
.env.*
!.env.template
!.env.*.template

# ─── Local Dev ────────────────────────────────────────────────────────────────
*.local
.DS_Store

# ─── Editor directories ────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
