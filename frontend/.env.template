# ==========================================
# SummitOS Frontend — Local Development Env
# ==========================================
# TEMPLATE ONLY. Copy to .env.local and fill in real values from Azure Key Vault.
# This file IS safe to commit. .env.local is NOT.
# ==========================================

# Backend API
AZURE_FUNCTION_URL=https://summitos-api.azurewebsites.net
AZURE_FUNCTION_KEY=<from-key-vault>

# Google Maps (public key — restrict to your domain in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<from-key-vault>
GOOGLE_PLACES_API_KEY=<from-key-vault>

# OAuth (Graph API - frontend client)
OAUTH_TENANT_ID=<from-key-vault>
OAUTH_CLIENT_ID=<from-key-vault>
OAUTH_CLIENT_SECRET=<from-key-vault>

# Email
RESEND_API_KEY=<from-key-vault>
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=PrivateTrips@costesla.com
SMTP_PASS=<from-key-vault>

# Stripe (use LIVE keys only in production)
STRIPE_SECRET_KEY=<from-key-vault>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<from-key-vault>

# Flight Status
AVIATIONSTACK_API_KEY=<from-key-vault>
