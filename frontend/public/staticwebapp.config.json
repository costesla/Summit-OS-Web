{
    "auth": {
        "identityProviders": {
            "azureActiveDirectory": {
                "userDetailsClaim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name",
                "registration": {
                    "openIdIssuer": "https://login.microsoftonline.com/common/v2.0",
                    "clientIdSettingName": "AAD_CLIENT_ID",
                    "clientSecretSettingName": "AAD_CLIENT_SECRET"
                }
            }
        }
    },
    "routes": [
        {
            "route": "/driver-login",
            "redirect": "/.auth/login/aad?post_login_redirect_uri=/driver-dashboard/"
        },
        {
            "route": "/driver-dashboard*",
            "allowedRoles": [
                "authenticated"
            ]
        }
    ],
    "responseOverrides": {
        "401": {
            "redirect": "/.auth/login/aad?post_login_redirect_uri=/driver-dashboard/",
            "statusCode": 302
        }
    },
    "rewrites": [
        {
            "route": "/api/dashboard-summary",
            "rewrite": "https://summitos-api.azurewebsites.net/api/dashboard-summary"
        },
        {
            "route": "/api/vehicle-location",
            "rewrite": "https://summitos-api.azurewebsites.net/api/vehicle-location"
        },
        {
            "route": "/api/quote",
            "rewrite": "https://summitos-api.azurewebsites.net/api/quote"
        },
        {
            "route": "/api/calendar-availability",
            "rewrite": "https://summitos-api.azurewebsites.net/api/calendar-availability"
        },
        {
            "route": "/api/calendar-book",
            "rewrite": "https://summitos-api.azurewebsites.net/api/calendar-book"
        },
        {
            "route": "/api/copilot/*",
            "rewrite": "https://summitos-api.azurewebsites.net/api/copilot/*"
        },
        {
            "route": "/api/book",
            "rewrite": "https://summitos-api.azurewebsites.net/api/book"
        },
        {
            "route": "/api/cabin/state",
            "rewrite": "https://summitos-api.azurewebsites.net/api/cabin/state"
        },
        {
            "route": "/api/cabin/command",
            "rewrite": "https://summitos-api.azurewebsites.net/api/cabin/command"
        },
        {
            "route": "/api/cabin",
            "rewrite": "https://summitos-api.azurewebsites.net/api/cabin/state"
        },
        {
            "route": "/api/update-payment",
            "rewrite": "https://summitsyncfuncus23436.azurewebsites.net/api/update-payment"
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/_next/*",
            "/driver-dashboard/*",
            "/images/*",
            "/*.{css,scss,js,json,png,gif,ico,jpg,svg,woff,woff2}"
        ]
    },
    "globalHeaders": {
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
    }
}